{
    "name": "token-extract",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "server": "node extractor-service/server.js",
        "start": "concurrently \"pnpm run dev\" \"pnpm run server\"",
