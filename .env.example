# TokenEngine Notification Settings
# Copy this file to .env and fill in your details

# Discord Webhook (Create in Discord -> Channel Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Telegram Bot Token & Chat ID (Alternative)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Admin Email for reporting
ADMIN_EMAIL=your_email@example.com
